diff --git a/2d/dodge_the_creeps/hud.gd b/2d/dodge_the_creeps/hud.gd
index b4504f1..39dae6b 100644
--- a/2d/dodge_the_creeps/hud.gd
+++ b/2d/dodge_the_creeps/hud.gd
@@ -4,0 +5,12 @@ signal start_game
+const SCORE_MILESTONE_INTERVAL = 5
+var reduced_motion := false
+
+func _ready():
+	$StartButton.focus_mode = Control.FOCUS_ALL
+	$StartButton.grab_focus()
+
+
+func set_reduced_motion(enabled):
+	reduced_motion = enabled
+
+
@@ -7,0 +20,4 @@ func show_message(text):
+	if not reduced_motion:
+		$MessageLabel.modulate.a = 0.0
+		var tween = create_tween()
+		tween.tween_property($MessageLabel, "modulate:a", 1.0, 0.12)
@@ -17,0 +34 @@ func show_game_over():
+	$StartButton.grab_focus()
@@ -21,0 +39,10 @@ func update_score(score):
+	if score > 0 and score % SCORE_MILESTONE_INTERVAL == 0:
+		_pulse_score()
+
+
+func _pulse_score():
+	if reduced_motion:
+		return
+	var tween = create_tween()
+	tween.tween_property($ScoreLabel, "scale", Vector2(1.12, 1.12), 0.08)
+	tween.tween_property($ScoreLabel, "scale", Vector2.ONE, 0.12)
@@ -25,0 +53 @@ func _on_StartButton_pressed():
+	$StartButton.release_focus()
diff --git a/2d/dodge_the_creeps/proof/portfolio_acceptance_checklist.md b/2d/dodge_the_creeps/proof/portfolio_acceptance_checklist.md
