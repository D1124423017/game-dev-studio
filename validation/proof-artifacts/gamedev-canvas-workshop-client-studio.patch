@@ -0,0 +1,82 @@
+import { existsSync, readFileSync } from 'node:fs';
+import { dirname, join, resolve } from 'node:path';
+import { fileURLToPath } from 'node:url';
+
+const root = resolve(dirname(fileURLToPath(import.meta.url)), '..');
+const requiredFiles = [
+  'studio-slice.html',
+  'src/game.js',
+  'src/ui.js',
+  'src/styles.css'
+];
+
+const failures = [];
+
+function assert(condition, message) {
+  if (!condition) {
+    failures.push(message);
+  }
+}
+
+function read(relativePath) {
+  return readFileSync(join(root, relativePath), 'utf8');
+}
+
+for (const file of requiredFiles) {
+  assert(existsSync(join(root, file)), `Missing ${file}`);
+}
+
+const html = read('studio-slice.html');
+const game = read('src/game.js');
+const ui = read('src/ui.js');
+const css = read('src/styles.css');
+
+assert(html.includes('class="studio-shell"'), 'HTML should include the studio shell layout');
+assert(html.includes('id="game-canvas"'), 'HTML should include a canvas gameplay surface');
+assert(html.includes('id="score-value"'), 'HTML should include DOM HUD values');
+assert(html.includes('id="result-card"'), 'HTML should include client-readable result UI');
+assert(html.includes('type="module"'), 'HTML should load modular JavaScript');
+assert(!html.includes('alert('), 'HTML should not rely on browser alerts');
+
+assert(game.includes('export function createInitialState'), 'Game module should expose initial state creation');
+assert(game.includes('export function createBreakoutGame'), 'Game module should expose game factory');
+assert(game.includes('hooks.onComplete'), 'Game module should report completion through hooks');
+assert(!game.includes('document.location.reload'), 'Game module should not reload the page for state changes');
+assert(!game.includes('alert('), 'Game module should not use blocking alerts');
+
+assert(ui.includes("import { createBreakoutGame }"), 'UI module should import the game module');
