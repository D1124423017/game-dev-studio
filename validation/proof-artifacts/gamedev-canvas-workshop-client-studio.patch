new file mode 100644
index 0000000..27fb222
--- /dev/null
+++ b/proof/src/game.js
@@ -0,0 +1,232 @@
+export const GAME_CONFIG = {
+  width: 480,
+  height: 320,
+  ballRadius: 9,
+  paddleWidth: 82,
+  paddleHeight: 12,
+  brickRows: 3,
+  brickColumns: 5,
+  brickWidth: 74,
+  brickHeight: 22,
+  brickPadding: 10,
+  brickOffsetTop: 52,
+  brickOffsetLeft: 28
+};
+
+export function createInitialState() {
+  return {
+    status: 'ready',
+    score: 0,
+    lives: 3,
+    combo: 0,
+    ball: {
+      x: GAME_CONFIG.width / 2,
+      y: GAME_CONFIG.height - 44,
+      dx: 2.4,
+      dy: -2.6
+    },
+    paddle: {
+      x: (GAME_CONFIG.width - GAME_CONFIG.paddleWidth) / 2
+    },
+    input: {
+      left: false,
+      right: false
+    },
+    bricks: Array.from({ length: GAME_CONFIG.brickColumns }, (_, column) =>
+      Array.from({ length: GAME_CONFIG.brickRows }, (_, row) => ({
+        x: 0,
+        y: 0,
+        column,
+        row,
+        active: true
+      }))
+    )
+  };
+}
+
+function resetBallAndPaddle(state) {
+  state.ball.x = GAME_CONFIG.width / 2;
+  state.ball.y = GAME_CONFIG.height - 44;
+  state.ball.dx = 2.4;
+  state.ball.dy = -2.6;
+  state.paddle.x = (GAME_CONFIG.width - GAME_CONFIG.paddleWidth) / 2;
+}
+
+function activeBrickCount(state) {
+  return state.bricks.flat().filter((brick) => brick.active).length;
+}
+
+function resolveBrickCollisions(state, hooks) {
+  for (const column of state.bricks) {
+    for (const brick of column) {
+      if (!brick.active) {
+        continue;
+      }
+
+      if (
+        state.ball.x > brick.x &&
+        state.ball.x < brick.x + GAME_CONFIG.brickWidth &&
+        state.ball.y > brick.y &&
+        state.ball.y < brick.y + GAME_CONFIG.brickHeight
+      ) {
+        state.ball.dy = -state.ball.dy;
+        brick.active = false;
+        state.score += 10;
+        state.combo += 1;
+        hooks.onBrickHit?.({ score: state.score, combo: state.combo });
+
+        if (activeBrickCount(state) === 0) {
+          state.status = 'won';
+          hooks.onComplete?.('won');
+        }
+      }
+    }
+  }
+}
+
+function update(state, hooks) {
+  if (state.status !== 'playing') {
+    return;
+  }
+
+  resolveBrickCollisions(state, hooks);
+
+  if (
+    state.ball.x + state.ball.dx > GAME_CONFIG.width - GAME_CONFIG.ballRadius ||
+    state.ball.x + state.ball.dx < GAME_CONFIG.ballRadius
+  ) {
+    state.ball.dx = -state.ball.dx;
+  }
+
+  if (state.ball.y + state.ball.dy < GAME_CONFIG.ballRadius) {
+    state.ball.dy = -state.ball.dy;
+  } else if (state.ball.y + state.ball.dy > GAME_CONFIG.height - GAME_CONFIG.ballRadius) {
+    const hitsPaddle =
+      state.ball.x > state.paddle.x &&
+      state.ball.x < state.paddle.x + GAME_CONFIG.paddleWidth;
+
+    if (hitsPaddle) {
+      state.ball.dy = -Math.abs(state.ball.dy);
+      state.combo = 0;
+      hooks.onPaddleHit?.();
+    } else {
+      state.lives -= 1;
+      state.combo = 0;
+      hooks.onLifeLost?.(state.lives);
+
+      if (state.lives <= 0) {
+        state.status = 'lost';
+        hooks.onComplete?.('lost');
+      } else {
+        resetBallAndPaddle(state);
+      }
+    }
+  }
+
+  if (state.input.right && state.paddle.x < GAME_CONFIG.width - GAME_CONFIG.paddleWidth) {
+    state.paddle.x += 6;
+  } else if (state.input.left && state.paddle.x > 0) {
+    state.paddle.x -= 6;
+  }
+
+  state.ball.x += state.ball.dx;
+  state.ball.y += state.ball.dy;
+}
+
+function drawRoundedPanel(ctx) {
+  const gradient = ctx.createLinearGradient(0, 0, GAME_CONFIG.width, GAME_CONFIG.height);
+  gradient.addColorStop(0, '#0b1020');
+  gradient.addColorStop(1, '#17213f');
+  ctx.fillStyle = gradient;
+  ctx.fillRect(0, 0, GAME_CONFIG.width, GAME_CONFIG.height);
+
+  ctx.strokeStyle = 'rgba(125, 211, 252, 0.26)';
+  ctx.lineWidth = 2;
+  ctx.strokeRect(8, 8, GAME_CONFIG.width - 16, GAME_CONFIG.height - 16);
+}
+
+function renderBricks(ctx, state) {
+  for (const column of state.bricks) {
+    for (const brick of column) {
+      if (!brick.active) {
+        continue;
+      }
+
+      brick.x = brick.row * (GAME_CONFIG.brickWidth + GAME_CONFIG.brickPadding) + GAME_CONFIG.brickOffsetLeft;
+      brick.y = brick.column * (GAME_CONFIG.brickHeight + GAME_CONFIG.brickPadding) + GAME_CONFIG.brickOffsetTop;
+      ctx.fillStyle = '#38bdf8';
+      ctx.shadowColor = 'rgba(56, 189, 248, 0.6)';
+      ctx.shadowBlur = 12;
+      ctx.fillRect(brick.x, brick.y, GAME_CONFIG.brickWidth, GAME_CONFIG.brickHeight);
+      ctx.shadowBlur = 0;
+    }
+  }
+}
+
+function renderBall(ctx, state) {
+  ctx.beginPath();
+  ctx.arc(state.ball.x, state.ball.y, GAME_CONFIG.ballRadius, 0, Math.PI * 2);
+  ctx.fillStyle = '#f8fafc';
+  ctx.shadowColor = 'rgba(248, 250, 252, 0.7)';
+  ctx.shadowBlur = 16;
+  ctx.fill();
+  ctx.closePath();
+  ctx.shadowBlur = 0;
+}
+
+function renderPaddle(ctx, state) {
+  ctx.fillStyle = '#f97316';
+  ctx.shadowColor = 'rgba(249, 115, 22, 0.45)';
+  ctx.shadowBlur = 14;
+  ctx.fillRect(state.paddle.x, GAME_CONFIG.height - GAME_CONFIG.paddleHeight - 16, GAME_CONFIG.paddleWidth, GAME_CONFIG.paddleHeight);
+  ctx.shadowBlur = 0;
+}
+
+function render(ctx, state) {
+  drawRoundedPanel(ctx);
+  renderBricks(ctx, state);
+  renderBall(ctx, state);
+  renderPaddle(ctx, state);
+}
+
+export function createBreakoutGame(canvas, hooks = {}) {
+  const ctx = canvas.getContext('2d');
+  let state = createInitialState();
+  let frame = 0;
+
+  function loop() {
+    update(state, hooks);
+    render(ctx, state);
+    hooks.onFrame?.(state);
+    frame = requestAnimationFrame(loop);
+  }
+
+  return {
+    getState: () => state,
+    start() {
+      if (state.status === 'playing') {
+        return;
+      }
+      state.status = 'playing';
+      hooks.onStatus?.('playing');
+      frame = requestAnimationFrame(loop);
+    },
+    restart() {
+      cancelAnimationFrame(frame);
+      state = createInitialState();
+      hooks.onStatus?.('ready');
+      render(ctx, state);
+    },
+    setInput(key, value) {
+      state.input[key] = value;
+    },
+    setPointerX(pointerX) {
+      const rect = canvas.getBoundingClientRect();
+      const scaledX = ((pointerX - rect.left) / rect.width) * GAME_CONFIG.width;
+      state.paddle.x = Math.max(0, Math.min(GAME_CONFIG.width - GAME_CONFIG.paddleWidth, scaledX - GAME_CONFIG.paddleWidth / 2));
+    },
+    renderInitial() {
+      render(ctx, state);
+    }
+  };
+}
