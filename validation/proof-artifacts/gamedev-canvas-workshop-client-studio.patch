+:root {
+  color-scheme: dark;
+  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
+  background: #080b14;
+  color: #f8fafc;
+}
+
+* {
+  box-sizing: border-box;
+}
+
+body {
+  min-height: 100vh;
+  margin: 0;
+  background:
+    radial-gradient(circle at 20% 12%, rgba(56, 189, 248, 0.28), transparent 30%),
+    radial-gradient(circle at 76% 18%, rgba(249, 115, 22, 0.16), transparent 28%),
+    linear-gradient(135deg, #080b14 0%, #111827 55%, #17213f 100%);
+}
+
+button {
+  font: inherit;
+}
+
+.studio-shell {
+  width: min(1180px, calc(100vw - 32px));
+  min-height: 100vh;
+  margin: 0 auto;
+  padding: 28px 0;
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) 320px;
+  gap: 20px;
+  align-items: center;
+}
+
+.stage-card,
+.hud-card,
+.brief-card,
+.result-card {
+  border: 1px solid rgba(148, 163, 184, 0.22);
+  background: rgba(15, 23, 42, 0.78);
+  box-shadow: 0 22px 70px rgba(0, 0, 0, 0.34);
+  backdrop-filter: blur(14px);
+}
+
+.stage-card {
+  position: relative;
+  border-radius: 8px;
+  overflow: hidden;
+}
+
+.stage-header {
+  padding: 20px 22px 14px;
+  border-bottom: 1px solid rgba(148, 163, 184, 0.16);
+}
+
+.eyebrow {
+  margin: 0 0 8px;
+  color: #7dd3fc;
+  font-size: 12px;
+  font-weight: 800;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+}
+
+h1,
+h2 {
+  margin: 0;
+  line-height: 1.05;
+}
+
+h1 {
+  font-size: clamp(34px, 6vw, 72px);
+}
+
+h2 {
+  font-size: 26px;
+}
+
+.lede {
+  width: min(620px, 100%);
+  margin: 12px 0 0;
+  color: #cbd5e1;
+  line-height: 1.6;
+}
+
+.canvas-wrap {
+  position: relative;
+  aspect-ratio: 3 / 2;
+  display: grid;
+  place-items: center;
+  padding: 18px;
+}
+
+canvas {
+  width: min(100%, 760px);
+  height: auto;
+  display: block;
+  border-radius: 8px;
+  border: 1px solid rgba(125, 211, 252, 0.24);
+  background: #0b1020;
+}
+
+.start-panel {
+  position: absolute;
+  inset: 18px;
+  display: grid;
+  place-items: center;
+  text-align: center;
+  background: rgba(8, 11, 20, 0.72);
+}
+
+.start-panel.is-hidden,
+.result-card.is-hidden {
+  display: none;
+}
+
+.start-panel-inner {
+  max-width: 420px;
+  padding: 24px;
+}
+
+.primary-action,
+.secondary-action {
+  min-height: 46px;
+  border: 0;
+  border-radius: 8px;
+  cursor: pointer;
+  font-weight: 800;
+  transition: transform 140ms ease, box-shadow 140ms ease, background-color 140ms ease;
+}
+
+.primary-action {
+  margin-top: 18px;
+  padding: 0 22px;
+  color: #111827;
+  background: #7dd3fc;
+  box-shadow: 0 14px 36px rgba(56, 189, 248, 0.26);
+}
+
+.secondary-action {
+  width: 100%;
+  color: #f8fafc;
+  background: rgba(248, 250, 252, 0.1);
+  border: 1px solid rgba(248, 250, 252, 0.18);
+}
+
+.primary-action:hover,
+.secondary-action:hover {
+  transform: translateY(-1px);
+}
+
+.primary-action:active,
+.secondary-action:active {
+  transform: translateY(1px);
+}
+
+.side-column {
+  display: grid;
+  gap: 16px;
+}
+
+.hud-card,
+.brief-card,
+.result-card {
+  border-radius: 8px;
+  padding: 18px;
+}
+
+.hud-grid {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  gap: 10px;
+  margin: 16px 0;
+}
+
+.hud-stat {
+  padding: 12px;
+  border-radius: 8px;
+  background: rgba(248, 250, 252, 0.08);
+}
+
+.hud-stat span {
+  display: block;
+  color: #94a3b8;
+  font-size: 12px;
+  font-weight: 700;
+}
+
+.hud-stat strong {
+  display: block;
+  margin-top: 6px;
+  font-size: 26px;
+}
+
+.status-line,
+.brief-card p,
+.result-card p {
+  color: #cbd5e1;
+  line-height: 1.55;
+}
+
+.brief-list {
+  margin: 14px 0 0;
+  padding-left: 18px;
+  color: #cbd5e1;
+  line-height: 1.65;
+}
+
+@media (max-width: 900px) {
+  .studio-shell {
+    grid-template-columns: 1fr;
+    align-items: start;
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  *,
+  *::before,
+  *::after {
+    scroll-behavior: auto !important;
+    transition-duration: 0.01ms !important;
+    animation-duration: 0.01ms !important;
+  }
+}
diff --git a/proof/src/ui.js b/proof/src/ui.js
new file mode 100644
index 0000000..33f7d30
--- /dev/null
+++ b/proof/src/ui.js
@@ -0,0 +1,119 @@
+import { createBreakoutGame } from './game.js';
+
+const canvas = document.querySelector('#game-canvas');
+const startPanel = document.querySelector('#start-panel');
+const startButton = document.querySelector('#start-button');
+const restartButton = document.querySelector('#restart-button');
+const resultCard = document.querySelector('#result-card');
+const resultTitle = document.querySelector('#result-title');
+const resultCopy = document.querySelector('#result-copy');
+const scoreValue = document.querySelector('#score-value');
+const livesValue = document.querySelector('#lives-value');
+const comboValue = document.querySelector('#combo-value');
+const stateValue = document.querySelector('#state-value');
+const statusLine = document.querySelector('#status-line');
+const motionPreference = window.matchMedia('(prefers-reduced-motion: reduce)');
+let audioContext;
+
+function playTone(frequency, duration = 0.08) {
+  if (motionPreference.matches) {
+    return;
+  }
+
+  audioContext ??= new AudioContext();
+  const oscillator = audioContext.createOscillator();
+  const gain = audioContext.createGain();
+  oscillator.frequency.value = frequency;
+  oscillator.type = 'triangle';
+  gain.gain.setValueAtTime(0.0001, audioContext.currentTime);
+  gain.gain.exponentialRampToValueAtTime(0.07, audioContext.currentTime + 0.01);
+  gain.gain.exponentialRampToValueAtTime(0.0001, audioContext.currentTime + duration);
+  oscillator.connect(gain).connect(audioContext.destination);
+  oscillator.start();
+  oscillator.stop(audioContext.currentTime + duration);
+}
+
+function setStatus(copy) {
+  statusLine.textContent = copy;
+}
+
+function updateHud(state) {
+  scoreValue.textContent = state.score;
+  livesValue.textContent = state.lives;
+  comboValue.textContent = `${state.combo}x`;
+  stateValue.textContent = state.status;
+}
+
+function showResult(result) {
+  const won = result === 'won';
+  resultCard.classList.remove('is-hidden');
+  resultTitle.textContent = won ? 'Client slice cleared' : 'Training failed';
+  resultCopy.textContent = won
+    ? 'The first playable loop has a readable win state, HUD feedback, and restart path.'
+    : 'The first playable loop has a readable failure state and restart path.';
+  setStatus(won ? 'Victory feedback delivered.' : 'Loss feedback delivered.');
+  playTone(won ? 740 : 180, 0.18);
+}
+
+const game = createBreakoutGame(canvas, {
+  onFrame: updateHud,
+  onStatus(status) {
+    updateHud(game.getState());
+    setStatus(status === 'playing' ? 'Break bricks, protect the ball, and keep the run alive.' : 'Ready for client review.');
+  },
+  onBrickHit(event) {
+    setStatus(`Brick cleared. Combo ${event.combo}x.`);
+    playTone(520 + event.combo * 20);
+  },
+  onPaddleHit() {
+    setStatus('Paddle return confirmed.');
+    playTone(340);
+  },
+  onLifeLost(lives) {
+    setStatus(`${lives} lives remaining.`);
+    playTone(160, 0.14);
+  },
+  onComplete: showResult
+});
+
+function beginSlice() {
+  startPanel.classList.add('is-hidden');
+  resultCard.classList.add('is-hidden');
+  game.start();
+}
+
+function restartSlice() {
+  resultCard.classList.add('is-hidden');
+  startPanel.classList.remove('is-hidden');
+  game.restart();
+  updateHud(game.getState());
+  setStatus('Ready for client review.');
+}
+
+document.addEventListener('keydown', (event) => {
+  if (event.code === 'ArrowLeft') {
+    game.setInput('left', true);
+  }
+  if (event.code === 'ArrowRight') {
+    game.setInput('right', true);
+  }
+});
+
+document.addEventListener('keyup', (event) => {
+  if (event.code === 'ArrowLeft') {
+    game.setInput('left', false);
+  }
+  if (event.code === 'ArrowRight') {
+    game.setInput('right', false);
+  }
+});
+
+canvas.addEventListener('pointermove', (event) => {
+  game.setPointerX(event.clientX);
+});
+
+startButton.addEventListener('click', beginSlice);
+restartButton.addEventListener('click', restartSlice);
+
+game.renderInitial();
+updateHud(game.getState());
