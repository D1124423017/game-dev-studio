+<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <title>Client Studio Breakout Slice</title>
+    <link rel="stylesheet" href="./src/styles.css">
+  </head>
+  <body>
+    <main class="studio-shell">
+      <section class="stage-card" aria-label="Playable Breakout slice">
+        <header class="stage-header">
+          <p class="eyebrow">Client first playable</p>
+          <h1>Crystal Breakout</h1>
+          <p class="lede">
+            A polished HTML Canvas gameplay slice with DOM-based HUD, state feedback,
+            restart flow, lightweight UI motion, and audio cues.
+          </p>
+        </header>
+
+        <div class="canvas-wrap">
+          <canvas id="game-canvas" width="480" height="320" aria-label="Breakout arena"></canvas>
+          <div class="start-panel" id="start-panel">
+            <div class="start-panel-inner">
+              <p class="eyebrow">Scope locked</p>
+              <h2>One complete loop</h2>
+              <p class="status-line">
+                Move with arrow keys or pointer. Clear the bricks, preserve lives,
+                and verify win/loss/restart feedback.
+              </p>
+              <button class="primary-action" id="start-button" type="button">Start Slice</button>
+            </div>
+          </div>
+        </div>
+      </section>
+
+      <aside class="side-column" aria-label="Client review panels">
+        <section class="hud-card" aria-label="Game HUD">
+          <p class="eyebrow">Run status</p>
+          <div class="hud-grid">
+            <div class="hud-stat">
+              <span>Score</span>
+              <strong id="score-value">0</strong>
+            </div>
+            <div class="hud-stat">
+              <span>Lives</span>
+              <strong id="lives-value">3</strong>
+            </div>
+            <div class="hud-stat">
+              <span>Combo</span>
+              <strong id="combo-value">0x</strong>
+            </div>
+            <div class="hud-stat">
+              <span>State</span>
+              <strong id="state-value">ready</strong>
+            </div>
+          </div>
+          <p class="status-line" id="status-line">Ready for client review.</p>
+        </section>
+
+        <section class="brief-card" aria-label="Scope notes">
+          <p class="eyebrow">MVP scope</p>
+          <ul class="brief-list">
+            <li>Keep the tutorial's Breakout core loop.</li>
+            <li>Separate DOM UI from Canvas gameplay rendering.</li>
+            <li>Replace browser alerts with client-readable result UI.</li>
+            <li>Add reduced-motion handling and lightweight audio cues.</li>
+          </ul>
+        </section>
+
+        <section class="result-card is-hidden" id="result-card" aria-live="polite">
+          <p class="eyebrow">Result</p>
+          <h2 id="result-title">Client slice cleared</h2>
+          <p id="result-copy">The first playable loop is ready for acceptance review.</p>
+          <button class="secondary-action" id="restart-button" type="button">Restart Review</button>
+        </section>
+      </aside>
+    </main>
+
+    <script type="module" src="./src/ui.js"></script>
+  </body>
+</html>
