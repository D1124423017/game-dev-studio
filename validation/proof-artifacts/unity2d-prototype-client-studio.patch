+import { existsSync, readFileSync } from 'node:fs';
+import { join, resolve } from 'node:path';
+
+const projectRoot = resolve(process.cwd());
+const failures = [];
+
+function assert(condition, message) {
+  if (!condition) {
+    failures.push(message);
+  }
+}
+
+function read(relativePath) {
+  return readFileSync(join(projectRoot, relativePath), 'utf8');
+}
+
+const requiredFiles = [
+  'README.md',
+  'LICENSE',
+  'Assets/Scripts/TitleMenu.cs',
+  'Assets/Scripts/Managers/GameManager.cs',
+  'Assets/Scripts/Actor.cs',
+  'Assets/Scripts/Collectable.cs',
+  'Assets/Scripts/Platformer/Platformer2DController.cs',
+  'Assets/Scenes/TitleScreen.unity',
+  'Assets/Scenes/SampleLevel.unity',
+  'Proof/client_studio_acceptance.md'
+];
+
+for (const file of requiredFiles) {
+  assert(existsSync(join(projectRoot, file)), `Missing ${file}`);
+}
+
+const readme = read('README.md');
+const license = read('LICENSE');
+const titleMenu = read('Assets/Scripts/TitleMenu.cs');
+const gameManager = read('Assets/Scripts/Managers/GameManager.cs');
+const actor = read('Assets/Scripts/Actor.cs');
+const controller = read('Assets/Scripts/Platformer/Platformer2DController.cs');
+const collectable = read('Assets/Scripts/Collectable.cs');
+const checklist = read('Proof/client_studio_acceptance.md');
+
+assert(readme.includes('2D Platformer Game'), 'README should identify the Unity 2D platformer sample');
+assert(readme.includes('User Interface (UI)'), 'README should record existing UI as an unfinished area');
+assert(license.includes('MIT License'), 'Project should keep MIT license evidence');
+assert(titleMenu.includes('[Header("Motion")]'), 'TitleMenu should expose motion settings');
+assert(titleMenu.includes('public bool ReducedMotion'), 'TitleMenu should expose reduced-motion control');
+assert(titleMenu.includes('PromptPulseSpeed'), 'TitleMenu should expose prompt pulse speed');
+assert(titleMenu.includes('PromptMinAlpha'), 'TitleMenu should expose prompt minimum alpha');
+assert(titleMenu.includes('UpdateStartPrompt()'), 'TitleMenu should isolate prompt motion from Update');
+assert(titleMenu.includes('ShouldStartGame()'), 'TitleMenu should isolate start input gating');
+assert(titleMenu.includes('SetStartTextAlpha'), 'TitleMenu should isolate TextMeshPro alpha updates');
+assert(titleMenu.includes('!Input.GetMouseButton(2)'), 'TitleMenu should guard middle mouse input');
+assert(titleMenu.includes('Time.unscaledTime'), 'Prompt motion should not depend on gameplay time scale');
+assert(!gameManager.includes('PromptPulseSpeed'), 'GameManager should not own title UI motion');
+assert(!gameManager.includes('SetStartTextAlpha'), 'GameManager should not own TextMeshPro prompt styling');
+assert(!actor.includes('PromptPulseSpeed'), 'Actor gameplay should not own title UI motion');
+assert(!controller.includes('PromptPulseSpeed'), 'Platformer input should not own title UI motion');
+assert(!collectable.includes('PromptPulseSpeed'), 'Collectables should not own title UI motion');
+assert(checklist.includes('Formal Art Direction'), 'Checklist should document the art direction gate');
+assert(checklist.includes('Architecture Boundary'), 'Checklist should document architecture boundaries');
+assert(checklist.includes('Runtime Unity play mode is required'), 'Checklist should not pretend runtime play mode passed');
+
+const lineCounts = {
+  titleMenu: titleMenu.split(/\r?\n/).filter(Boolean).length,
+  gameManager: gameManager.split(/\r?\n/).filter(Boolean).length,
+  actor: actor.split(/\r?\n/).filter(Boolean).length,
+  controller: controller.split(/\r?\n/).filter(Boolean).length
+};
+
+assert(lineCounts.titleMenu < 80, `TitleMenu proof slice should stay small: ${lineCounts.titleMenu} lines`);
+assert(lineCounts.gameManager < 40, `GameManager should remain focused: ${lineCounts.gameManager} lines`);
+assert(lineCounts.actor < 60, `Actor should remain focused: ${lineCounts.actor} lines`);
+assert(lineCounts.controller < 40, `Controller should remain focused: ${lineCounts.controller} lines`);
+
+if (failures.length > 0) {
+  console.error(failures.map((failure) => `[FAIL] ${failure}`).join('\n'));
+  process.exit(1);
+}
+
+console.log('unity2d prototype proof static smoke: passed');
