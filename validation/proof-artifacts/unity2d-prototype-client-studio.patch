+using System.Collections;
+using System.Collections.Generic;
+using TMPro;
+using UnityEngine;
+using UnityEngine.SceneManagement;
+using UnityEngine.UI;
+
+public class TitleMenu : MonoBehaviour
+{
+    [Header("UI")]
+    public TextMeshProUGUI StartGameText;
+    [Header("Audio")]
+    public AudioPlayer BackgroundMusic;
+    public AudioPlayer AmbientSoundFX;
+    public AudioPlayer VoiceSoundFX;
+    public AudioPlayer CursorSoundFX;
+    public AudioPlayer ConfirmSoundFX;
+    [Header("Motion")]
+    public bool ReducedMotion;
+    [Min(0f)] public float PromptPulseSpeed = 2.8f;
+    [Range(0f, 1f)] public float PromptMinAlpha = 0.55f;
+
+    private bool _pendingStartGame;
+    private Color _startGameTextBaseColor;
+
+    private void Awake()
+    {
+        if (StartGameText != null)
+            _startGameTextBaseColor = StartGameText.color;
+        BackgroundMusic.Play();
+        AmbientSoundFX.Play();
+        VoiceSoundFX.Play();
+    }
+
+    void Update()
+    {
+        UpdateStartPrompt();
+        if (ShouldStartGame())
+            StartCoroutine(StartGame());
+    }
+
+    private bool ShouldStartGame()
+    {
+        if (_pendingStartGame || !Input.anyKeyDown)
+            return false;
+        return !Input.GetMouseButton(0) && !Input.GetMouseButton(1) && !Input.GetMouseButton(2);
+    }
+
+    private void UpdateStartPrompt()
+    {
+        if (StartGameText == null || _pendingStartGame)
+            return;
+        if (ReducedMotion)
+        {
+            SetStartTextAlpha(_startGameTextBaseColor.a);
+            return;
+        }
+        float pulse = (Mathf.Sin(Time.unscaledTime * PromptPulseSpeed) + 1f) * 0.5f;
+        float alpha = Mathf.Lerp(PromptMinAlpha, _startGameTextBaseColor.a, pulse);
+        SetStartTextAlpha(alpha);
+    }
+
+    private void SetStartTextAlpha(float alpha)
+    {
+        Color color = _startGameTextBaseColor;
+        color.a = alpha;
+        StartGameText.color = color;
+    }
+
+    private IEnumerator StartGame()
+    {
+        if (_pendingStartGame) yield break;
+        _pendingStartGame = true;
+        if (StartGameText != null)
+            SetStartTextAlpha(_startGameTextBaseColor.a);
+        StartGameText.enabled = false;
+        BackgroundMusic.Stop();
+        AmbientSoundFX.Stop();
+        VoiceSoundFX.Stop();
+        ConfirmSoundFX.Play();
+        yield return new WaitWhile(() => ConfirmSoundFX.IsPlaying);
+        SceneManager.LoadScene(SceneManager.GetActiveScene().buildIndex + 1);
+        _pendingStartGame = false;
+    }
+}
