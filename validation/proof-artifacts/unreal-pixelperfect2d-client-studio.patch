+// Copyright Epic Games, Inc. All Rights Reserved.
+
+#include "SampleGameViewportClient.h"
+
+void USampleGameViewportClient::Activated(FViewport* InViewport, const FWindowActivateEvent& InActivateEvent)
+{
+    Super::Activated(InViewport, InActivateEvent);
+
+    ApplyPixelPerfectShowFlags();
+}
+
+void USampleGameViewportClient::Draw(FViewport* InViewport, FCanvas* SceneCanvas)
+{
+    ApplyPixelPerfectShowFlags();
+    Super::Draw(InViewport, SceneCanvas);
+}
+
+void USampleGameViewportClient::ApplyPixelPerfectShowFlags()
+{
+    // Keep Paper2D sprites crisp in editor, PIE, and packaged runtime paths.
+    EngineShowFlags.PostProcessing = 0;
+}
